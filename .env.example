# Copy to .env and adjust. All models are local/open-source — no cloud API keys.

# --- LLM (OpenAI-compatible endpoint) ---
# Dev = Ollama; Prod = vLLM. Only the base_url changes.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:8b
LLM_REWRITE_MODEL=qwen3:1.7b
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT=120

# --- HuggingFace (optional; only raises model-download rate limits) ---
HF_TOKEN=

# --- Embeddings (CPU, open-source) ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=1024

# --- Reranker (CPU, open-source) ---
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu

# --- Neo4j (graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag_dev_pw
NEO4J_DATABASE=neo4j

# --- Qdrant (vectors) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=graphrag_chunks

# --- Retrieval / fusion ---
RETRIEVER_TOP_K=20
RRF_K=60
RERANK_CANDIDATE_K=20
RERANK_TOP_N=6
# Drop chunks the cross-encoder scores below this floor (blank = off). BGE-reranker
# emits logits where >0 ≈ relevant; 0.0 is a sane start once you've tuned for recall.
RERANK_SCORE_FLOOR=

# --- Agent loop ---
FAITHFULNESS_THRESHOLD=0.7
MAX_ITERATIONS=3
# Total wall-clock budget for the agent loop, seconds (0 disables). On overrun the loop
# returns the best answer so far and the rewrite step skips its LLM call.
AGENT_TIME_BUDGET_S=30

# --- Observability ---
# Log level for Strata internals (DEBUG|INFO|WARNING|ERROR). Quiet by default;
# INFO surfaces retrieval counts, critic verdicts, and agent routing.
STRATA_LOG_LEVEL=WARNING
